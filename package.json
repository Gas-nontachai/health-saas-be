{
  "name": "blood-sugar-tracking-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/migrate-on-render-build.mjs",
    "start": "node dist/src/server.js",
