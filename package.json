    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "jose": "^5.9.6",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.15.2",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.13.8",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
